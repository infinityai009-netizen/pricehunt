# ─── Auth.js / NextAuth v5 ────────────────────────────────────────────────────
# Copy this file to .env.local for local dev, or add each var in the Vercel
# dashboard at https://vercel.com/<your-team>/pricehunt/settings/environment-variables
# Any provider whose keys are missing is simply hidden — the demo fallback
# kicks in instead so the site never breaks.

# ── REQUIRED for any real OAuth flow ────────────────────────────────────────
# Generate with: `openssl rand -base64 32` or use https://generate-secret.vercel.app/32
AUTH_SECRET=
# Public site URL (Vercel sets this automatically — leave blank in production)
NEXTAUTH_URL=

# ── Google Sign-In ──────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. "Create credentials" → "OAuth client ID" → Web application
# 3. Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Facebook Sign-In ────────────────────────────────────────────────────────
# 1. https://developers.facebook.com/apps → Create app → Consumer
# 2. Add "Facebook Login" product
# 3. Valid OAuth Redirect URI: https://YOUR-DOMAIN/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# ── GitHub Sign-In ──────────────────────────────────────────────────────────
# 1. https://github.com/settings/developers → "OAuth Apps" → New
# 2. Authorization callback URL: https://YOUR-DOMAIN/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Email magic links (via Resend) ──────────────────────────────────────────
# 1. Sign up free at https://resend.com (100 emails/day free)
# 2. Create an API key
# 3. Verify your domain (or use the test sender during dev)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PriceHunt <noreply@yourdomain.com>"

# ─── Product feed APIs (existing) ─────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_AFFILIATE_CAMPAIGN_ID=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.co.uk
AMAZON_REGION=eu-west-1
AWIN_PUBLISHER_ID=
AWIN_API_TOKEN=
